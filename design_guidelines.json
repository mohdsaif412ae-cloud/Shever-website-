{
  "brand_identity": {
    "name": "Shever Technical",
    "tone": "Professional, Reliable, Engineering-focused, Trustworthy",
    "archetype": "The Expert / The Maker",
    "core_values": ["Precision", "Efficiency", "Modernity"],
    "target_audience": "Corporate and residential clients in Dubai"
  },
  "typography": {
    "font_family": {
      "headings": "Poppins, sans-serif",
      "body": "Inter, sans-serif",
      "mono": "JetBrains Mono, monospace"
    },
    "scale": {
      "h1": "text-5xl md:text-6xl font-bold tracking-tight",
      "h2": "text-4xl md:text-5xl font-semibold tracking-tight",
      "h3": "text-2xl md:text-3xl font-semibold",
      "p": "text-base md:text-lg leading-relaxed text-muted-foreground",
      "label": "text-xs font-bold uppercase tracking-widest text-muted-foreground"
    },
    "instructions": "Import 'Poppins' from Google Fonts (weights: 400, 500, 600, 700). Use Poppins for all Headings (h1-h4). Use Inter for body text."
  },
  "colors": {
    "palette": {
      "primary": "#1F1F1F",
      "secondary": "#FFFFFF",
      "accent": "#4FC3F7",
      "accent_foreground": "#0F172A",
      "muted": "#F1F5F9",
      "border": "#E2E8F0",
      "background": "#FFFFFF",
      "foreground": "#1F1F1F"
    },
    "css_variables": {
      "root": {
        "--background": "0 0% 100%",
        "--foreground": "0 0% 12%",
        "--primary": "0 0% 12%",
        "--primary-foreground": "0 0% 100%",
        "--secondary": "0 0% 96%",
        "--secondary-foreground": "0 0% 12%",
        "--accent": "199 91% 64%",
        "--accent-foreground": "0 0% 100%",
        "--muted": "210 40% 96.1%",
        "--muted-foreground": "215.4 16.3% 46.9%",
        "--border": "214.3 31.8% 91.4%",
        "--input": "214.3 31.8% 91.4%",
        "--ring": "199 91% 64%"
      },
      "dark": {
        "--background": "0 0% 12%",
        "--foreground": "0 0% 100%",
        "--primary": "0 0% 100%",
        "--primary-foreground": "0 0% 12%",
        "--secondary": "0 0% 15%",
        "--secondary-foreground": "0 0% 100%",
        "--accent": "199 91% 64%",
        "--accent-foreground": "0 0% 100%",
        "--muted": "0 0% 15%",
        "--muted-foreground": "215 20.2% 65.1%",
        "--border": "0 0% 20%",
        "--input": "0 0% 20%",
        "--ring": "199 91% 64%"
      }
    },
    "usage_rules": {
      "buttons": "Primary buttons use Accent color (#4FC3F7) with dark text or Primary Dark (#1F1F1F) with white text. Secondary buttons are outline or ghost.",
      "backgrounds": "Main background is White (#FFFFFF). Section backgrounds alternate between White and Muted Grey (#F8FAFC). Dark sections use Primary (#1F1F1F).",
      "text": "Headings are Primary (#1F1F1F). Body text is Slate-600 or Slate-700. In dark sections, text is White."
    }
  },
  "layout": {
    "grid_system": {
      "default": "grid grid-cols-1 md:grid-cols-12 gap-6",
      "bento": "grid grid-cols-1 md:grid-cols-3 gap-4 auto-rows-[minmax(180px,auto)]",
      "dashboard": "grid grid-cols-1 md:grid-cols-4 gap-4"
    },
    "spacing": {
      "section_padding": "py-20 md:py-32",
      "container_padding": "px-6 md:px-12 lg:px-24",
      "component_gap": "gap-6"
    },
    "container": {
      "max_width": "max-w-7xl mx-auto"
    }
  },
  "components": {
    "buttons": {
      "style": "rounded-full font-medium px-8 py-6 transition-all duration-300 hover:scale-[1.02] active:scale-[0.98]",
      "primary": "bg-primary text-primary-foreground hover:bg-primary/90",
      "accent": "bg-accent text-accent-foreground hover:bg-accent/90"
    },
    "cards": {
      "style": "bg-card text-card-foreground rounded-xl border border-border/50 shadow-sm hover:shadow-md transition-all duration-300 hover:border-accent/50 group",
      "service_card": "p-8 flex flex-col items-start gap-4",
      "project_card": "overflow-hidden rounded-xl relative aspect-[4/3]"
    },
    "inputs": {
      "style": "h-12 rounded-lg border-input bg-background px-4 py-2 text-sm ring-offset-background file:border-0 file:bg-transparent file:text-sm file:font-medium placeholder:text-muted-foreground focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 disabled:cursor-not-allowed disabled:opacity-50"
    },
    "navigation": {
      "style": "sticky top-0 z-50 w-full border-b border-border/40 bg-background/95 backdrop-blur supports-[backdrop-filter]:bg-background/60",
      "link": "text-sm font-medium transition-colors hover:text-accent"
    }
  },
  "images": {
    "style": "rounded-xl object-cover",
    "assets": {
      "hero_bg": "https://images.unsplash.com/photo-1763581804286-683d28919444?crop=entropy&cs=srgb&fm=jpg&ixid=M3w4NTYxODh8MHwxfHNlYXJjaHwzfHxkdWJhaSUyMHNreWxpbmUlMjBtb2Rlcm4lMjBidWlsZGluZ3xlbnwwfHx8fDE3NzI3NTAxOTd8MA&ixlib=rb-4.1.0&q=85",
      "hvac_service": "https://images.unsplash.com/photo-1753964724380-2c5ae02512a8?crop=entropy&cs=srgb&fm=jpg&ixid=M3w4NjA2MTJ8MHwxfHNlYXJjaHw0fHx0ZWNobmljaWFuJTIwaHZhYyUyMG1haW50ZW5hbmNlfGVufDB8fHx8MTc3Mjc1MDE5Nnww&ixlib=rb-4.1.0&q=85",
      "electrical_service": "https://images.unsplash.com/photo-1601462904263-f2fa0c851cb9?crop=entropy&cs=srgb&fm=jpg&ixid=M3w4NjA1MDV8MHwxfHNlYXJjaHwxfHxlbGVjdHJpY2lhbiUyMHdpcmluZyUyMHByb2Zlc3Npb25hbHxlbnwwfHx8fDE3NzI3NTAxOTh8MA&ixlib=rb-4.1.0&q=85",
      "plumbing_service": "https://images.unsplash.com/photo-1723988429049-0a42e45e8501?crop=entropy&cs=srgb&fm=jpg&ixid=M3w3NTY2NzF8MHwxfHNlYXJjaHwxfHxwbHVtYmluZyUyMHJlcGFpciUyMHRvb2xzfGVufDB8fHx8MTc3Mjc1MDE5OXww&ixlib=rb-4.1.0&q=85",
      "painting_service": "https://images.unsplash.com/photo-1688372199140-cade7ae820fe?crop=entropy&cs=srgb&fm=jpg&ixid=M3w4NjA5MTN8MHwxfHNlYXJjaHwyfHxwYWludGluZyUyMHdhbGwlMjBwYWludGVyfGVufDB8fHx8MTc3Mjc1MDE5OXww&ixlib=rb-4.1.0&q=85",
      "logo_placeholder": "/assets/logo-placeholder.svg"
    }
  },
  "motion": {
    "default_transition": "all 0.3s cubic-bezier(0.4, 0, 0.2, 1)",
    "hover_lift": "hover:-translate-y-1 hover:shadow-lg",
    "fade_in": {
      "initial": { "opacity": 0, "y": 20 },
      "animate": { "opacity": 1, "y": 0 },
      "transition": { "duration": 0.5 }
    },
    "stagger": 0.1
  },
  "pages": {
    "home": {
      "sections": [
        "Hero (Full height, bg image with dark overlay, centered text)",
        "Services (Grid of 3x3 or carousel)",
        "Why Us (Split layout: Text Left, Image Right)",
        "Projects (Horizontal scroll or Masonry grid)",
        "Testimonials (Cards)",
        "CTA (Full width, accent background)"
      ]
    },
    "services": {
      "layout": "Grid of detail cards with icons"
    },
    "projects": {
      "layout": "Masonry grid with category filters"
    },
    "contact": {
      "layout": "Two column: Info + Map (Left), Form (Right)"
    },
    "admin": {
      "layout": "Sidebar navigation (Left), Content area (Right). High density tables/cards."
    }
  },
  "universal_guidelines": [
    "Do not use generic gradients. Use solid colors or subtle noise textures.",
    "Use generous padding (py-24+) for sections to create a premium feel.",
    "Ensure all text on dark backgrounds is legible (text-white or text-slate-200).",
    "Interactive elements must have clear hover and focus states.",
    "Use 'lucide-react' for icons.",
    "Data-testid attributes are mandatory for all interactive elements.",
    "Images must have alt text for accessibility.",
    "Forms must use shadcn/ui form components with validation (zod)."
  ]
}